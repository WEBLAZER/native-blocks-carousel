{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"description": "Demo v9 for Any Block Carousel Slider",
	"steps": [
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/WEBLAZER/native-blocks-carousel/main/assets/plugin.zip"
			}
		},
		{
			"step": "installTheme",
			"themeData": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/WEBLAZER/native-blocks-carousel/main/assets/theme.zip"
			}
		},
		{
			"step": "activatePlugin",
			"pluginPath": "native-blocks-carousel/any-block-carousel-slider.php"
		},
		{
			"step": "activateTheme",
			"themeFolderName": "native-blocks-carousel"
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/WEBLAZER/native-blocks-carousel/main/assets/demo-content.xml"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php \nif ( file_exists( 'wp-load.php' ) ) {\n    require_once 'wp-load.php';\n}\n\n$home = get_page_by_path('sample-page');\nif ($home) {\n\tupdate_option('show_on_front', 'page');\n\tupdate_option('page_on_front', $home->ID);\n}\nupdate_option('permalink_structure', '/%postname%/');"
		}
	],
	"landingPage": "/sample-page/"
}
